<div class="mx-auto max-w-3xl px-4 py-10">
  <div class="mb-8">
    <p class="text-sm font-bold uppercase tracking-[0.25em] text-amber-300/80">Forge</p>
    <h1 class="mt-3 text-3xl font-black tracking-tight text-zinc-100">Add Exercise</h1>
    <p class="mt-2 text-zinc-400">Add a movement, sets, reps, and load to this workout.</p>
  </div>
  <div class="rounded-3xl border border-white/10 bg-zinc-900/70 p-6 shadow-2xl shadow-black/20">
    <%= render "form", workout: @workout, exercise_entry: @exercise_entry %>
  </div>
</div>