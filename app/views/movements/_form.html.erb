<%= form_with(model: movement, class: "contents") do |form| %>
  <% if movement.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(movement.errors.count, "error") %> prohibited this movement from being saved:</h2>

      <ul class="list-disc ml-6">
        <% movement.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :name %>
    <%= form.text_field :name, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": movement.errors[:name].none?, "border-red-400 focus:outline-red-600": movement.errors[:name].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :current_cue %>
    <%= form.textarea :current_cue, rows: 4, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": movement.errors[:current_cue].none?, "border-red-400 focus:outline-red-600": movement.errors[:current_cue].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :progression_rule %>
    <%= form.textarea :progression_rule, rows: 4, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": movement.errors[:progression_rule].none?, "border-red-400 focus:outline-red-600": movement.errors[:progression_rule].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :notes %>
    <%= form.textarea :notes, rows: 4, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": movement.errors[:notes].none?, "border-red-400 focus:outline-red-600": movement.errors[:notes].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
