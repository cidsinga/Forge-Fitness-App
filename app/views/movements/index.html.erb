<% content_for :title, "Movements" %>

<section class="mx-auto max-w-5xl space-y-8">
  <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-bold uppercase tracking-[0.22em] text-amber-200/80">Training Memory</p>
      <h1 class="mt-3 text-4xl font-black tracking-tight text-white sm:text-5xl">Movements</h1>
      <p class="mt-4 max-w-2xl text-base leading-7 text-zinc-400">
        Store durable cues, progression rules, and notes for the lifts and movement patterns you return to over time.
      </p>
    </div>

    <%= link_to "New Movement",
      new_movement_path,
      class: "inline-flex justify-center rounded-2xl bg-amber-400 px-5 py-3 text-sm font-black text-zinc-950 shadow-lg shadow-amber-950/30 transition hover:-translate-y-0.5 hover:bg-amber-300" %>
  </div>

  <% if notice.present? %>
    <div class="rounded-2xl border border-emerald-400/20 bg-emerald-400/10 px-4 py-3 text-sm font-bold text-emerald-200">
      <%= notice %>
    </div>
  <% end %>

  <% if @movements.any? %>
    <div class="grid gap-4 sm:grid-cols-2">
      <% @movements.each do |movement| %>
<article class="rounded-3xl border border-white/10 bg-zinc-900/80 p-6 shadow-xl shadow-black/20 transition hover:-translate-y-0.5 hover:border-amber-300/30 hover:bg-zinc-900">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-zinc-500">Movement</p>
      <h2 class="mt-2 text-2xl font-black tracking-tight text-white">
        <%= movement.name %>
      </h2>
    </div>

    <%= link_to "View",
      movement,
      class: "shrink-0 rounded-2xl border border-white/10 px-4 py-2 text-sm font-bold text-zinc-200 transition hover:bg-white/10 hover:text-white" %>
  </div>

  <% if movement.current_cue.present? %>
    <div class="mt-5 rounded-2xl border border-amber-300/15 bg-amber-300/10 p-4">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-amber-200/80">Current cue</p>
      <p class="mt-2 text-sm leading-6 text-zinc-200">
        <%= truncate(movement.current_cue, length: 140) %>
      </p>
    </div>
  <% end %>

  <% if movement.progression_rule.present? %>
    <p class="mt-4 text-sm leading-6 text-zinc-400">
      <span class="font-bold text-zinc-300">Progression:</span>
      <%= truncate(movement.progression_rule, length: 130) %>
    </p>
  <% end %>
</article>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-3xl border border-white/10 bg-zinc-900/80 p-8 text-center shadow-xl shadow-black/20">
      <p class="text-lg font-bold text-white">No movements yet.</p>
      <p class="mt-2 text-zinc-400">Start with a movement you train often, like Back Squat or Bench Press.</p>

      <%= link_to "Create your first movement",
        new_movement_path,
        class: "mt-6 inline-flex justify-center rounded-2xl bg-amber-400 px-5 py-3 text-sm font-black text-zinc-950 transition hover:bg-amber-300" %>
    </div>
  <% end %>
</section>