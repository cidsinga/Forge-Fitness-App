<!DOCTYPE html>
<html class="h-full bg-zinc-950">
  <head>
    <title><%= content_for(:title) || "Forge Fitness App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= favicon_link_tag "icon.png", rel: "icon", type: "image/png" if asset_path("icon.png") rescue nil %>
    <%= favicon_link_tag "icon.svg", rel: "icon", type: "image/svg+xml" if asset_path("icon.svg") rescue nil %>
    <%= favicon_link_tag "icon.png", rel: "apple-touch-icon" if asset_path("icon.png") rescue nil %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="min-h-full bg-[radial-gradient(circle_at_top_left,_rgba(245,158,11,0.16),_transparent_32%),radial-gradient(circle_at_top_right,_rgba(34,197,94,0.10),_transparent_28%),linear-gradient(180deg,_#09090b_0%,_#18181b_100%)] text-zinc-100 antialiased">
    <div class="min-h-screen">
      <header class="border-b border-white/10 bg-zinc-950/70 backdrop-blur-xl">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <%= link_to root_path, class: "group flex items-center gap-3" do %>
            <div class="flex h-10 w-10 items-center justify-center rounded-2xl border border-amber-400/30 bg-amber-400/10 shadow-lg shadow-amber-950/40">
              <span class="text-lg font-black tracking-tight text-amber-300">F</span>
            </div>
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-300/80">Forge</p>
              <p class="text-xs text-zinc-400">Evidence of who you’re becoming</p>
            </div>
          <% end %>
          <nav class="flex items-center gap-5">
            <%= link_to "Workouts",
    workouts_path,
    class: [
      "text-sm font-bold transition hover:text-amber-200",
      current_page?(workouts_path) ? "text-amber-200" : "text-zinc-300"
    ].join(" ") %>
            <%= link_to "Movements",
    movements_path,
    class: [
      "text-sm font-bold transition hover:text-amber-200",
      current_page?(movements_path) ? "text-amber-200" : "text-zinc-300"
    ].join(" ") %>
            <%= link_to "Log Workout",
  new_workout_path,
  class: "rounded-full bg-amber-400 px-6 py-3 text-sm font-black text-zinc-950 shadow-lg shadow-amber-950/30 transition hover:-translate-y-0.5 hover:bg-amber-300" %>
          </nav>
        </div>
      </header>
      <% if notice.present? %>
        <div class="mx-auto max-w-6xl px-4 pt-6 sm:px-6 lg:px-8">
          <div class="rounded-2xl border border-emerald-400/20 bg-emerald-400/10 px-4 py-3 text-sm font-medium text-emerald-200">
            <%= notice %>
          </div>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="mx-auto max-w-6xl px-4 pt-6 sm:px-6 lg:px-8">
          <div class="rounded-2xl border border-red-400/20 bg-red-400/10 px-4 py-3 text-sm font-medium text-red-200">
            <%= alert %>
          </div>
        </div>
      <% end %>
      <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
        <%= yield %>
      </main>
    </div>
  </body>
</html>