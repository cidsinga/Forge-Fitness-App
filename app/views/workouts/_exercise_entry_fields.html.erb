<div class="rounded-3xl border border-white/10 bg-black/25 p-4" data-exercise-entries-target="row">
  <%= entry_form.hidden_field :id if entry_form.object.persisted? %>
  <% position_value = entry_form.object.position.presence || (entry_form.index.to_s.match?(/\A\d+\z/) ? entry_form.index.to_i + 1 : nil) %>
  <%= entry_form.hidden_field :position, value: position_value %>
  <%= entry_form.hidden_field :_destroy, value: "0" %>
  <div class="mb-4 flex items-center justify-between gap-4">
    <p class="text-sm font-black text-zinc-300">Exercise</p>
    <button type="button"
      class="rounded-xl border border-white/10 px-3 py-1.5 text-xs font-bold text-zinc-400 transition hover:bg-white/10 hover:text-white"
      data-action="exercise-entries#remove">
      Remove
    </button>
  </div>
  <div class="grid gap-4 sm:grid-cols-12">
    <div class="sm:col-span-5">
      <%= entry_form.label :movement_id, "Movement", class: "block text-sm font-bold text-zinc-200" %>
      <%= entry_form.collection_select :movement_id,
        Movement.order(:name),
        :id,
        :name,
        { prompt: "Choose a movement" },
        class: "mt-2 block w-full rounded-xl border border-white/10 bg-zinc-950 px-4 py-3 text-zinc-100 shadow-sm outline-none transition focus:border-amber-400/50 focus:ring-2 focus:ring-amber-400/20" %>
    </div>
    <div class="sm:col-span-2">
      <%= entry_form.label :sets, class: "block text-sm font-bold text-zinc-200" %>
      <%= entry_form.number_field :sets,
        min: 1,
        placeholder: "3",
        class: "mt-2 block w-full rounded-xl border border-white/10 bg-zinc-950 px-4 py-3 text-zinc-100 shadow-sm outline-none transition focus:border-amber-400/50 focus:ring-2 focus:ring-amber-400/20" %>
    </div>
    <div class="sm:col-span-2">
      <%= entry_form.label :reps, class: "block text-sm font-bold text-zinc-200" %>
      <%= entry_form.number_field :reps,
        min: 1,
        placeholder: "8",
        class: "mt-2 block w-full rounded-xl border border-white/10 bg-zinc-950 px-4 py-3 text-zinc-100 shadow-sm outline-none transition focus:border-amber-400/50 focus:ring-2 focus:ring-amber-400/20" %>
    </div>
    <div class="sm:col-span-3">
      <%= entry_form.label :weight, "Weight", class: "block text-sm font-bold text-zinc-200" %>
      <%= entry_form.number_field :weight,
        min: 0,
        step: "0.5",
        placeholder: "145",
        class: "mt-2 block w-full rounded-xl border border-white/10 bg-zinc-950 px-4 py-3 text-zinc-100 shadow-sm outline-none transition focus:border-amber-400/50 focus:ring-2 focus:ring-amber-400/20" %>
    </div>
  </div>
  <div class="mt-4">
    <%= entry_form.label :notes, "Entry notes", class: "block text-sm font-bold text-zinc-200" %>
    <%= entry_form.text_field :notes,
      placeholder: "Optional note for this movement",
      class: "mt-2 block w-full rounded-xl border border-white/10 bg-zinc-950 px-4 py-3 text-zinc-100 shadow-sm outline-none transition focus:border-amber-400/50 focus:ring-2 focus:ring-amber-400/20" %>
  </div>
</div>