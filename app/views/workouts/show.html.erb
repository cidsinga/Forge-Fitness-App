<% content_for :title, "Workout" %>
<% exercise_entries = @workout.exercise_entries.includes(:movement).ordered.to_a %>
<% total_sets = exercise_entries.sum { |entry| entry.sets.to_i } %>
<section class="mx-auto max-w-4xl space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <%= link_to "← Back to workouts", workouts_path, class: "text-sm font-bold text-zinc-400 transition hover:text-amber-200" %>
    <div class="flex items-center gap-2">
      <%= link_to "Edit", edit_workout_path(@workout), class: "rounded-2xl border border-white/10 px-4 py-2 text-sm font-bold text-zinc-200 transition hover:bg-white/10 hover:text-white" %>
      <%= button_to "Delete",
        @workout,
        method: :delete,
        data: { turbo_confirm: "Delete this workout?" },
        class: "rounded-2xl border border-red-400/20 px-4 py-2 text-sm font-bold text-red-200 transition hover:bg-red-400/10" %>
    </div>
  </div>
  <article class="overflow-hidden rounded-3xl border border-white/10 bg-zinc-900/80 shadow-2xl shadow-black/30">
    <div class="border-b border-white/10 bg-white/[0.03] px-6 py-6 sm:px-8">
      <div class="flex flex-wrap items-center gap-3">
        <span class="rounded-full border border-amber-300/20 bg-amber-300/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-amber-200">
          <%= @workout.workout_type.presence || "Workout" %>
        </span>
        <time class="text-sm font-medium text-zinc-400">
          <%= @workout.date&.strftime("%A, %B %-d, %Y") || "No date" %>
        </time>
      </div>
      <div class="mt-5 flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.22em] text-zinc-500">Workout log</p>
          <h1 class="mt-2 text-4xl font-black tracking-tight text-white">
            <%= @workout.workout_type.presence || "Workout" %>
          </h1>
        </div>
        <%= link_to "Add Exercise",
          new_workout_exercise_entry_path(@workout),
          class: "inline-flex items-center justify-center rounded-2xl bg-amber-300 px-5 py-3 text-sm font-black text-zinc-950 transition hover:bg-amber-200" %>
      </div>
    </div>
    <div class="grid gap-3 px-6 py-5 sm:grid-cols-2 sm:px-8">
      <div class="rounded-3xl border border-white/10 bg-black/25 p-4">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Exercises</p>
        <p class="mt-2 text-2xl font-black text-white"><%= exercise_entries.size %></p>
      </div>
      <div class="rounded-3xl border border-white/10 bg-black/25 p-4">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Total sets</p>
        <p class="mt-2 text-2xl font-black text-white"><%= total_sets %></p>
      </div>
    </div>
  </article>
  <section class="rounded-3xl border border-white/10 bg-zinc-900/80 p-6 shadow-2xl shadow-black/30 sm:p-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.22em] text-zinc-500">Logged exercises</p>
        <h2 class="mt-2 text-2xl font-black tracking-tight text-white">Movements performed</h2>
      </div>
      <%= link_to "Add Exercise",
        new_workout_exercise_entry_path(@workout),
        class: "inline-flex items-center justify-center rounded-2xl border border-amber-300/30 bg-amber-300/10 px-4 py-2 text-sm font-black text-amber-200 transition hover:bg-amber-300 hover:text-zinc-950" %>
    </div>
    <% if exercise_entries.any? %>
      <div class="mt-6 space-y-3">
        <% exercise_entries.each do |entry| %>
          <div class="rounded-3xl border border-white/10 bg-black/30 p-5 transition hover:border-white/20 hover:bg-black/40">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <div class="flex flex-wrap items-center gap-3">
                  <h3 class="text-lg font-black text-white">
                    <%= entry.movement.name %>
                  </h3>
                  <% if entry.movement.respond_to?(:tag) && entry.movement.tag.present? %>
                    <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-1 text-xs font-bold uppercase tracking-[0.14em] text-zinc-400">
                      <%= entry.movement.tag %>
                    </span>
                  <% end %>
                </div>
                <% if entry.summary.present? %>
                  <p class="mt-2 text-sm font-semibold text-amber-100">
                    <%= entry.summary %>
                  </p>
                <% end %>
                <% if entry.notes.present? %>
                  <p class="mt-3 max-w-2xl text-sm leading-6 text-zinc-400">
                    <%= entry.notes %>
                  </p>
                <% end %>
              </div>
              <div class="flex shrink-0 items-center gap-2">
                <%= link_to "Edit",
                  edit_workout_exercise_entry_path(@workout, entry),
                  class: "rounded-2xl border border-white/10 px-3 py-1.5 text-sm font-bold text-zinc-200 transition hover:bg-white/10 hover:text-white" %>
                <%= button_to "Remove",
                  workout_exercise_entry_path(@workout, entry),
                  method: :delete,
                  data: { turbo_confirm: "Remove this exercise entry?" },
                  class: "rounded-2xl border border-red-400/20 px-3 py-1.5 text-sm font-bold text-red-200 transition hover:bg-red-400/10" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="mt-6 rounded-3xl border border-dashed border-white/10 bg-black/20 p-8 text-center">
        <p class="text-lg font-black text-zinc-200">No exercises logged yet.</p>
        <p class="mt-2 text-sm text-zinc-500">Start turning raw notes into structured training history.</p>
        <%= link_to "Add first exercise",
          new_workout_exercise_entry_path(@workout),
          class: "mt-5 inline-flex items-center justify-center rounded-2xl bg-amber-300 px-5 py-3 text-sm font-black text-zinc-950 transition hover:bg-amber-200" %>
      </div>
    <% end %>
  </section>
  <section class="rounded-3xl border border-white/10 bg-zinc-900/60 p-6 shadow-2xl shadow-black/20 sm:p-8">
    <div class="mb-3 flex items-center justify-between">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.22em] text-zinc-500">Raw notes</p>
        <h2 class="mt-2 text-xl font-black tracking-tight text-white">Scratchpad</h2>
      </div>
      <span class="text-xs font-medium text-zinc-600">Version 1 capture</span>
    </div>
    <div class="rounded-3xl border border-white/10 bg-black/30 p-5">
      <pre class="whitespace-pre-wrap font-mono text-sm leading-7 text-zinc-300"><%= @workout.raw_notes.presence || "No notes recorded." %></pre>
    </div>
  </section>
</section>