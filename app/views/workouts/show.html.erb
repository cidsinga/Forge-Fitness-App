<% content_for :title, "Workout" %>
<section class="mx-auto max-w-4xl space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <%= link_to "← Back to workouts", workouts_path, class: "text-sm font-bold text-zinc-400 transition hover:text-amber-200" %>
    <div class="flex items-center gap-2">
      <%= link_to "Edit", edit_workout_path(@workout), class: "rounded-2xl border border-white/10 px-4 py-2 text-sm font-bold text-zinc-200 transition hover:bg-white/10 hover:text-white" %>
      <%= button_to "Delete",
        @workout,
        method: :delete,
        data: { turbo_confirm: "Delete this workout?" },
        class: "rounded-2xl border border-red-400/20 px-4 py-2 text-sm font-bold text-red-200 transition hover:bg-red-400/10" %>
    </div>
  </div>
  <article class="overflow-hidden rounded-3xl border border-white/10 bg-zinc-900/80 shadow-2xl shadow-black/30">
    <div class="border-b border-white/10 bg-white/[0.03] px-6 py-6 sm:px-8">
      <div class="flex flex-wrap items-center gap-3">
        <span class="rounded-full border border-amber-300/20 bg-amber-300/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-amber-200">
          <%= @workout.workout_type.presence || "Workout" %>
        </span>
        <time class="text-sm font-medium text-zinc-400">
          <%= @workout.date&.strftime("%A, %B %-d, %Y") || "No date" %>
        </time>
      </div>
      <h1 class="mt-5 text-4xl font-black tracking-tight text-white">
        <%= @workout.workout_type.presence || "Workout" %>
      </h1>
    </div>
    <div class="px-6 py-6 sm:px-8">
      <div class="mb-3 flex items-center justify-between">
        <h2 class="text-sm font-bold uppercase tracking-[0.22em] text-zinc-500">Raw notes</h2>
        <span class="text-xs font-medium text-zinc-600">Version 1 capture</span>
      </div>
      <div class="rounded-3xl border border-white/10 bg-black/30 p-5">
        <pre class="whitespace-pre-wrap font-mono text-sm leading-7 text-zinc-200"><%= @workout.raw_notes.presence || "No notes recorded." %></pre>
      </div>
    </div>
  </article>
  <section class="rounded-3xl border border-white/10 bg-zinc-900/80 p-6 shadow-2xl shadow-black/30 sm:p-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.22em] text-zinc-500">Exercise entries</p>
        <h2 class="mt-2 text-2xl font-black tracking-tight text-white">Movements logged</h2>
      </div>
      <%= link_to "Add Exercise",
        new_workout_exercise_entry_path(@workout),
        class: "inline-flex items-center justify-center rounded-2xl bg-amber-300 px-4 py-2 text-sm font-black text-zinc-950 transition hover:bg-amber-200" %>
    </div>
    <% if @workout.exercise_entries.any? %>
      <div class="mt-6 space-y-3">
        <% @workout.exercise_entries.includes(:movement).ordered.each do |entry| %>
          <div class="rounded-3xl border border-white/10 bg-black/30 p-5">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <h3 class="text-lg font-black text-white">
                  <%= entry.movement.name %>
                </h3>
                <% if entry.summary.present? %>
                  <p class="mt-1 text-sm font-semibold text-zinc-300">
                    <%= entry.summary %>
                  </p>
                <% end %>
                <% if entry.notes.present? %>
                  <p class="mt-3 text-sm leading-6 text-zinc-400">
                    <%= entry.notes %>
                  </p>
                <% end %>
              </div>
              <div class="flex shrink-0 items-center gap-2">
                <%= link_to "Edit",
                  edit_workout_exercise_entry_path(@workout, entry),
                  class: "rounded-2xl border border-white/10 px-3 py-1.5 text-sm font-bold text-zinc-200 transition hover:bg-white/10 hover:text-white" %>
                <%= button_to "Remove",
                  workout_exercise_entry_path(@workout, entry),
                  method: :delete,
                  data: { turbo_confirm: "Remove this exercise entry?" },
                  class: "rounded-2xl border border-red-400/20 px-3 py-1.5 text-sm font-bold text-red-200 transition hover:bg-red-400/10" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="mt-6 rounded-3xl border border-dashed border-white/10 bg-black/20 p-6 text-center">
        <p class="font-bold text-zinc-300">No exercise entries yet.</p>
        <p class="mt-1 text-sm text-zinc-500">Add the first movement for this workout.</p>
      </div>
    <% end %>
  </section>
</section>