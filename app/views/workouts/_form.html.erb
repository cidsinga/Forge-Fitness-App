<%= form_with(model: workout, class: "space-y-6") do |form| %>
  <% if workout.errors.any? %>
    <div class="rounded-2xl border border-red-400/20 bg-red-400/10 p-4">
      <h2 class="text-sm font-bold text-red-200">
        <%= pluralize(workout.errors.count, "error") %> kept this workout from being saved.
      </h2>

      <ul class="mt-3 list-disc space-y-1 pl-5 text-sm text-red-100/90">
        <% workout.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <%= form.label :date, class: "block text-sm font-bold text-zinc-200" %>
      <%= form.date_field :date, class: "mt-2 block w-full rounded-2xl border border-white/10 bg-zinc-950/80 px-4 py-3 text-zinc-100 shadow-inner shadow-black/30 outline-none transition placeholder:text-zinc-600 focus:border-amber-300/60 focus:ring-4 focus:ring-amber-300/10" %>
    </div>

    <div>
      <%= form.label :workout_type, "Workout type", class: "block text-sm font-bold text-zinc-200" %>
      <%= form.text_field :workout_type, placeholder: "Lower, Upper, CrossFit, Olympic...", class: "mt-2 block w-full rounded-2xl border border-white/10 bg-zinc-950/80 px-4 py-3 text-zinc-100 shadow-inner shadow-black/30 outline-none transition placeholder:text-zinc-600 focus:border-amber-300/60 focus:ring-4 focus:ring-amber-300/10" %>
    </div>
  </div>

  <div>
    <div class="flex items-end justify-between gap-4">
      <%= form.label :raw_notes, "Raw workout notes", class: "block text-sm font-bold text-zinc-200" %>
      <span class="text-xs font-medium text-zinc-500">Use #MovementName to structure entries.</span>
    </div>

    <%= form.text_area :raw_notes,
      rows: 16,
      placeholder: "#BackSquat
5x3 @ 205
205 is a good challenge.
Nail the technique at this weight.
Cue: traps into bar.

#RDL
3x10 @ 175
Felt good.
Grip got tired on the last set.

#Notes
Energy was decent.
Lower back felt fine.
Keep depth honest.",
      class: "mt-2 block w-full rounded-3xl border border-white/10 bg-zinc-950/80 px-4 py-4 font-mono text-sm leading-6 text-zinc-100 shadow-inner shadow-black/30 outline-none transition placeholder:text-zinc-700 focus:border-amber-300/60 focus:ring-4 focus:ring-amber-300/10" %>
  </div>

  <div class="flex flex-col-reverse gap-3 border-t border-white/10 pt-6 sm:flex-row sm:items-center sm:justify-between">
    <%= link_to "Cancel", workouts_path, class: "inline-flex justify-center rounded-2xl border border-white/10 px-5 py-3 text-sm font-bold text-zinc-300 transition hover:bg-white/10 hover:text-white" %>

    <%= form.submit class: "inline-flex cursor-pointer justify-center rounded-2xl bg-amber-400 px-5 py-3 text-sm font-black text-zinc-950 shadow-lg shadow-amber-950/30 transition hover:-translate-y-0.5 hover:bg-amber-300" %>
  </div>
<% end %>