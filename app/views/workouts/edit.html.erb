<% content_for :title, "Edit workout" %>

<section class="mx-auto max-w-3xl">
  <div class="mb-8">
    <%= link_to "← Back to workout", @workout, class: "text-sm font-bold text-zinc-400 transition hover:text-amber-200" %>

    <p class="mt-8 text-sm font-semibold uppercase tracking-[0.28em] text-amber-300/80">Refine the record</p>
    <h1 class="mt-3 text-4xl font-black tracking-tight text-white">Edit workout</h1>
    <p class="mt-4 text-base leading-7 text-zinc-400">
      Keep the record honest. Notes, cues, and context matter.
    </p>
  </div>

  <div class="rounded-3xl border border-white/10 bg-zinc-900/80 p-5 shadow-2xl shadow-black/30 sm:p-8">
    <%= render "form", workout: @workout %>
  </div>
</section>